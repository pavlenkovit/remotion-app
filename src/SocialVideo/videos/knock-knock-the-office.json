      }
    },
    {
      "from": 70.88,
      "to": 71.72,
      "text": "- I'm not gonna answer it.",
      "tr": {
        "ru": "— Я не буду отвечать.",
        "es": "- No voy a contestar."
      }
    },
    {
      "from": 71.72,
      "to": 72.56,
      "text": "- I'm not gonna answer it.",
      "tr": {
        "ru": "— Я не буду отвечать.",
        "es": "- No voy a contestar."
      }
    },
    {
      "from": 72.56,
      "to": 73.4,
      "text": "It's the KGB.",
      "tr": {
        "ru": "Это КГБ.",
        "es": "Es la KGB."
      }
    },
    {
      "from": 73.4,
      "to": 74.48,
      "text": "- The KGB will fit for no one.",
      "tr": {
        "ru": "— КГБ никому не подойдёт.",
        "es": "- La KGB no es adecuada para nadie."
      }
    },
    {
      "from": 76.74,
