  "subtitles": [
    {
      "from": 0,
      "to": 1.66,
      "text": "- BAM, knock, knock.",
      "tr": {
        "ru": "— БАМ, тук-тук.",
        "es": "- ¡BAM!, toc, toc."
      }
    },
    {
      "from": 1.66,
      "to": 2.5,
      "text": "- I'm on the phone.",
      "tr": {
        "ru": "— Я говорю по телефону.",
        "es": "- Estoy al teléfono."
      }
    },
    {
      "from": 2.5,
      "to": 3.32,
      "text": "- I know you are, knock, knock.",
      "tr": {
        "ru": "— Я знаю, что ты здесь, тук-тук.",
        "es": "- Sé que lo eres, toc, toc."
      }
    },
    {
      "from": 3.32,
      "to": 4.94,
      "text": "- You can fax it over.",
      "tr": {
        "ru": "— Вы можете отправить его по факсу.",
        "es": "- Puedes enviarlo por fax."
      }
    },
    {
      "from": 4.94,
      "to": 7.02,
      "text": "Yeah, five, seven, zero.",
      "tr": {
        "ru": "Да, пять, семь, ноль.",
        "es": "Sí, cinco, siete, cero."
      }
    },
    {
      "from": 7.02,
      "to": 7.86,
      "text": "Five, five, five.",
      "tr": {
        "ru": "Пять, пять, пять.",
        "es": "Cinco, cinco, cinco."
      }
    },
    {
      "from": 7.86,
      "to": 9.1,
      "text": "- Four, five, nine, one.",
      "tr": {
        "ru": "— Четыре, пять, девять, один.",
        "es": "- Cuatro, cinco, nueve, uno."
      }
    },
    {
      "from": 9.1,
      "to": 9.94,
      "text": "- Zero, one.",
      "tr": {
        "ru": "- Ноль, один.",
        "es": "- Cero, uno."
      }
    },
    {
      "from": 9.94,
      "to": 10.76,
      "text": "- Seven, four.",
      "tr": {
        "ru": "— Семь, четыре.",
        "es": "- Siete, cuatro."
      }
    },
    {
      "from": 10.76,
      "to": 12.66,
      "text": "- Five-ling.",
      "tr": {
        "ru": "- Пятилинг.",
        "es": "- Cinco-ling."
      }
    },
    {
      "from": 12.66,
      "to": 14.46,
      "text": "- Zero, one, seven, five.",
      "tr": {
        "ru": "— Ноль, один, семь, пять.",
        "es": "- Cero, uno, siete, cinco."
      }
    },
    {
      "from": 14.46,
      "to": 15.5,
      "text": "Thank you.",
      "tr": {
        "ru": "Спасибо.",
        "es": "Gracias."
      }
    },
    {
      "from": 15.5,
      "to": 16.34,
      "text": "Bye-bye.",
      "tr": {
        "ru": "Пока-пока.",
        "es": "Adiós."
      }
    },
    {
      "from": 16.34,
      "to": 19.06,
      "text": "- That really makes us look unprofessional.",
      "tr": {
        "ru": "— Это действительно выставляет нас в непрофессиональном свете.",
        "es": "Eso nos hace parecer poco profesionales."
      }
    },
    {
      "from": 19.06,
      "to": 20.42,
      "text": "- They would never know it was me doing it.",
      "tr": {
        "ru": "— Они никогда не узнают, что это сделал я.",
        "es": "- Jamás sabrían que fui yo quien lo hizo."
      }
    },
    {
      "from": 20.42,
      "to": 21.66,
      "text": "Here we go, knock, knock.",
      "tr": {
        "ru": "Ну вот, тук-тук.",
        "es": "Aquí vamos, toc, toc."
      }
    },
    {
      "from": 21.66,
      "to": 24.74,
      "text": "- Who's there?",
      "tr": {
        "ru": "— Кто там?",
        "es": "- ¿Quién está ahí?"
      }
    },
    {
      "from": 24.74,
      "to": 25.66,
      "text": "- Buddha.",
      "tr": {
        "ru": "- Будда.",
        "es": "- Buda."
      }
    },
    {
      "from": 25.66,
      "to": 26.5,
      "text": "- Buddha who?",
      "tr": {
        "ru": "— Будда кто?",
        "es": "- ¿Buda quién?"
      }
    },
    {
      "from": 26.5,
      "to": 27.5,
      "text": "- Buddha that's bred for every--",
      "tr": {
        "ru": "- Будда, созданный для всех...",
        "es": "- Buda que se cría para todos--"
      }
    },
    {
      "from": 31.18,
      "to": 32.18,
      "text": "- Great.",
      "tr": {
        "ru": "- Большой.",
        "es": "- Excelente."
      }
    },
    {
      "from": 32.18,
      "to": 34.14,
      "text": "- I need something to wipe my hand.",
      "tr": {
        "ru": "— Мне нужно чем-нибудь вытереть руки.",
        "es": "- Necesito algo para limpiarme la mano."
      }
    },
    {
      "from": 34.14,
      "to": 35.38,
      "text": "- No, there's butter on my nose.",
      "tr": {
        "ru": "— Нет, у меня на носу масло.",
        "es": "- No, tengo mantequilla en la nariz."
      }
    },
    {
      "from": 35.38,
      "to": 36.42,
      "text": "- That was melting.",
      "tr": {
        "ru": "— Оно таяло.",
        "es": "- Eso se estaba derritiendo."
      }
    },
    {
      "from": 36.42,
      "to": 37.26,
      "text": "- It was a classic.",
      "tr": {
        "ru": "— Это была классика.",
        "es": "- Fue un clásico."
      }
    },
    {
      "from": 37.26,
      "to": 38.38,
      "text": "- I got a knock, knock joke.",
      "tr": {
        "ru": "— У меня есть шутка про стук в дверь.",
        "es": "- Tengo un chiste de \"toc, toc\"."
      }
    },
    {
      "from": 38.38,
      "to": 39.22,
      "text": "- No.",
      "tr": {
        "ru": "- Нет.",
        "es": "- No."
      }
    },
    {
      "from": 39.22,
      "to": 40.06,
      "text": "- Okay, God.",
