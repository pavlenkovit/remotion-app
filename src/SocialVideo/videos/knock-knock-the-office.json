    },
    {
      "from": 66.68,
      "to": 67.52,
      "text": "- Ding dong.",
      "tr": {
        "ru": "- Дин-дон.",
        "es": "-Ding dong."
      }
    },
    {
      "from": 67.52,
      "to": 68.36,
      "text": "- No way, it's the KGB.",
      "tr": {
        "ru": "— Нет, это же КГБ.",
        "es": "- De ninguna manera, es la KGB."
      }
    },
    {
      "from": 68.36,
      "to": 69.2,
      "text": "- Ding dong.",
      "tr": {
        "ru": "- Дин-дон.",
        "es": "-Ding dong."
      }
    },
    {
      "from": 69.2,
      "to": 70.04,
      "text": "- I'm not answering that.",
      "tr": {
        "ru": "— Я на это отвечать не буду.",
