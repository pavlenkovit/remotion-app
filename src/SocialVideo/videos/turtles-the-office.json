  "subtitles": [
    {
      "from": 2.92,
      "to": 9.3,
      "text": "- Did you forget something?",
      "tr": {
        "ru": "— Ты что-то забыл?",
        "es": "¿Olvidaste algo?"
      }
    },
    {
      "from": 9.3,
      "to": 10.5,
      "text": "What happened to you guys?",
      "tr": {
        "ru": "Что с вами случилось?",
        "es": "¿Qué les pasó?"
      }
    },
    {
      "from": 10.5,
      "to": 11.34,
      "text": "- Give it back.",
      "tr": {
        "ru": "— Верните это.",
        "es": "- Devuélvelo."
      }
    },
    {
      "from": 11.34,
      "to": 15.82,
      "text": "The gift basket, give it back.",
      "tr": {
        "ru": "Верните подарочную корзину.",
        "es": "Devuelva la cesta de regalo."
      }
    },
    {
      "from": 15.82,
      "to": 17.02,
      "text": "- What is this?",
      "tr": {
        "ru": "- Что это?",
        "es": "- ¿Qué es esto?"
      }
    },
    {
      "from": 17.02,
      "to": 18.1,
      "text": "- It's real simple.",
      "tr": {
        "ru": "— Всё очень просто.",
        "es": "- Es muy sencillo."
      }
    },
    {
      "from": 18.1,
      "to": 20.5,
      "text": "If you don't appreciate what we do,",
      "tr": {
        "ru": "Если вам не нравится то, что мы делаем,",
        "es": "Si no aprecias lo que hacemos,"
      }
    },
    {
      "from": 20.5,
      "to": 22.16,
      "text": "then give us back our basket.",
      "tr": {
        "ru": "Тогда верните нам нашу корзину.",
        "es": "Entonces devuélvannos nuestra cesta."
      }
    },
    {
      "from": 22.16,
      "to": 23.5,
      "text": "- Maybe you should leave.",
      "tr": {
        "ru": "— Может, тебе стоит уйти?",
        "es": "- Quizás deberías irte."
      }
    },
    {
      "from": 23.5,
      "to": 27.3,
      "text": "- Yeah, maybe we should, maybe we should leave.",
      "tr": {
        "ru": "— Да, может быть, нам стоит, может быть, нам стоит уйти.",
        "es": "- Sí, tal vez deberíamos, tal vez deberíamos irnos."
      }
    },
    {
      "from": 27.3,
      "to": 29.94,
      "text": "Come on, let's leave, but before we leave,",
      "tr": {
        "ru": "Пойдем, но прежде чем уйти,",
        "es": "Vamos, vámonos, pero antes de irnos,"
      }
    },
    {
      "from": 29.94,
      "to": 31.44,
      "text": "my wet friend and I are gonna wait",
      "tr": {
        "ru": "Мы с моим мокрым другом будем ждать.",
        "es": "Mi amigo mojado y yo vamos a esperar"
      }
    },
    {
      "from": 31.44,
      "to": 34.54,
      "text": "for our cabs on your nice couches.",
      "tr": {
        "ru": "для наших такси на ваших удобных диванах.",
        "es": "para nuestros taxis en sus cómodos sofás."
      }
    },
    {
      "from": 34.54,
      "to": 36.04,
      "text": "- Can you call us a cab, please?",
      "tr": {
        "ru": "— Не могли бы вы вызвать нам такси, пожалуйста?",
        "es": "¿Podrías llamarnos un taxi, por favor?"
      }
    },
    {
      "from": 36.04,
      "to": 37.74,
      "text": "I'm gonna, oh, sorry.",
      "tr": {
        "ru": "Я собираюсь, ой, извините.",
        "es": "Voy a, oh, lo siento."
      }
    },
    {
      "from": 37.74,
      "to": 39.14,
      "text": "- Look, my clothes are so wet.",
      "tr": {
        "ru": "— Смотри, моя одежда вся мокрая.",
        "es": "- Mira, mi ropa está empapada."
      }
    },
    {
      "from": 39.14,
      "to": 41.26,
      "text": "- Wet, nice leather.",
      "tr": {
        "ru": "- Влажная, приятная на ощупь кожа.",
        "es": "- Cuero húmedo y agradable."
      }
    },
    {
      "from": 41.26,
      "to": 43.82,
      "text": "Oh, my shoes are so muddy.",
      "tr": {
        "ru": "Ох, мои ботинки такие грязные.",
        "es": "¡Ay, mis zapatos están tan llenos de barro!"
      }
    },
    {
      "from": 43.82,
      "to": 46.46,
      "text": "All right, here you go, take it back.",
      "tr": {
        "ru": "Хорошо, вот, забирайте свои слова обратно.",
        "es": "Muy bien, aquí tienes, retíralo."
      }
    },
    {
      "from": 46.46,
      "to": 47.3,
      "text": "- It's been opened.",
      "tr": {
        "ru": "— Оно открыто.",
        "es": "- Ya está abierto."
      }
    },
    {
      "from": 47.3,
      "to": 48.2,
      "text": "- Yeah, it was mine.",
      "tr": {
        "ru": "— Да, это было моё.",
        "es": "- Sí, era mío."
      }
    },
    {
      "from": 48.2,
      "to": 49.42,
      "text": "- What's missing?",
      "tr": {
        "ru": "— Чего не хватает?",
        "es": "- ¿Qué falta?"
      }
    },
    {
      "from": 49.42,
      "to": 52.1,
      "text": "- The turtles.",
      "tr": {
        "ru": "- Черепахи.",
        "es": "- Las tortugas."
      }
    },
    {
      "from": 52.1,
      "to": 52.98,
      "text": "- Where are the turtles?",
      "tr": {
        "ru": "— Где черепахи?",
        "es": "- ¿Dónde están las tortugas?"
      }
    },
    {
      "from": 52.98,
      "to": 53.82,
      "text": "Where are the turtles?",
      "tr": {
        "ru": "Где черепахи?",
        "es": "¿Dónde están las tortugas?"
      }
    },
    {
      "from": 53.82,
      "to": 55.02,
      "text": "- Come on, guys, get out of here.",
      "tr": {
        "ru": "— Ну же, ребята, уходите отсюда.",
